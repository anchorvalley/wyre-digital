---
import Base from '../layouts/Base.astro';
---
<Base
  title="Wyre Digital - The Financial Layer for Serious Business"
  description="Financial infrastructure built on BSV blockchain, offering stablecoins and immutable records for enterprises."
  ogTitle="Wyre Digital - The Financial Layer for Serious Business"
  ogDescription="Financial infrastructure built on BSV blockchain, offering stablecoins and immutable records for enterprises."
  ogImage="/images/wyre-og.jpg" <!-- Assume an image -->
  canonical="https://wyre.digital"
>
  <div class="page-wrapper line-bg">
    <div class="section_hero">
      <div class="padding-global-2">
        <div class="container-large">
          <div>
            <div class="w-layout-grid features_grid-wrapper">
              <div class="w-layout-grid features_grid">
                <!-- Optional image -->
                <div id="w-node-f1c50e53-4826-24a6-2f85-0c31e40a3502-edb2f681" class="features_content-wrapper">
                  <h1><strong>The Financial Layer for Serious Business.</strong></h1>
                  <div class="padding-small"></div>
                  <p>Scalable, low-cost financial infrastructure powered by the BSV blockchain, designed for enterprises and developers needing reliability and efficiency.</p>
                  <div class="spacer-medium"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="section_body-content">
      <div class="padding-global-2">
        <div class="container-large">
          <div class="padding-section-small">
            <div class="div_fake-button-wrapper">
              <p class="fake-button"><strong>BSV-Native</strong></p>
              <p class="fake-button"><strong>Tamper-Proof</strong></p>
              <p class="fake-button"><strong>Sub-Cent Fees</strong></p>
              <p class="fake-button"><strong>Enterprise-Ready</strong></p>
              <p class="fake-button"><strong>Open Infrastructure</strong></p>
              <p class="fake-button"><strong>Audit-Ready</strong></p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="section_body-content">
      <div class="padding-global-2">
        <div class="container-large">
          <div class="padding-section-medium">
            <h2>Our Products</h2>
            <div class="spacer-medium"></div>
            <div class="w-layout-grid grid_industries">
              <div class="padding-medium flex">
                <h5>WYRE</h5>
                <p>Stablecoin platform for seamless financial transactions.</p>
                <p><strong>Coming Soon</strong></p>
                <a href="/products" class="underlined link">Learn More</a>
              </div>
              <div class="padding-medium flex">
                <h5>Immutable Records</h5>
                <p>Tamper-proof data anchoring on BSV blockchain.</p>
                <p><strong>Live</strong></p>
                <a href="/immutable-records" class="underlined link">Learn More</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="section_body-content">
      <div class="padding-global-2">
        <div class="container-large">
          <div class="padding-section-medium">
            <h2>How Immutable Records Works</h2>
            <div class="spacer-medium"></div>
            <ul role="list">
              <li class="underlined"><strong>Step 1:</strong> Hash your data for a unique fingerprint.</li>
              <li class="underlined"><strong>Step 2:</strong> Anchor the hash to the BSV blockchain.</li>
              <li class="underlined"><strong>Step 3:</strong> Verify integrity anytime with our API.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    <div class="section_pre-footer">
      <div class="padding-global-2 no-bottom">
        <div class="container-large">
          <div class="padding-section-medium flex no-bottom">
            <h2 class="align-center tight">Get Early Access</h2>
            <div class="spacer-large"></div>
            <div class="cta_wrapper">
              <div class="cta-flex">
                <a href="/contact" class="button is-large w-button">Sign Up Now</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>