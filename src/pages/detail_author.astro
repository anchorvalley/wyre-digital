---
import Base from '../layouts/Base.astro';
---
<Base
  title="| Author at Anchor Valley"
  description=""
  ogTitle="| Author at Aidium"
  ogDescription=""
  ogImage=""
  canonical="https://www.anchorvalleygroup.com/detail_author"
>
  <div class="page-wrapper line-bg">
<div class="section_hero">
      <div class="padding-global-2">
        <div class="container-large">
          <div class="padding-section-medium flex">
            <p class="text-style-title">blog author</p>
            <h1 class="align-center tight w-dyn-bind-empty"></h1>
            <div class="spacer-large"></div>
            <p class="text-style-title w-dyn-bind-empty"></p>
            <div class="spacer-large"></div><img src="https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg" loading="lazy" alt="" class="i-15rem w-dyn-bind-empty">
            <div class="spacer-large"></div>
            <p class="align-center tight w-dyn-bind-empty"></p>
          </div>
          <div class="padding-section-medium">
            <div class="div_logo-wrapper">
              <div class="line-wrapper">
                <div class="blue-line"></div>
                <div class="spacer_horizontal-small"></div>
                <h5 class="text-style-nowrap">Articles written by</h5>
                <div class="spacer_horizontal-small"></div>
                <h5 class="text-style-nowrap w-dyn-bind-empty"></h5>
                <div class="spacer_horizontal-small"></div>
                <div class="blue-line"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="section_body-content">
      <div class="padding-global-2">
        <div class="container-large">
          <div class="padding-section-medium">
            <div class="collection-list-wrapper-2 w-dyn-list">
              <div role="list" class="collection-list-2 w-dyn-items">
                <div role="listitem" class="w-dyn-item">
                  <div class="padding-medium clients blog">
                    <a href="#" class="w-inline-block"><img src="https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg" loading="lazy" alt="" class="i-blog-post w-dyn-bind-empty">
                      <div class="spacer-large"></div>
                      <h5 class="w-dyn-bind-empty"></h5>
                    </a>
                    <div class="align-bottom">
                      <a href="#" class="link-author-wrap w-inline-block">
                        <div class="div_author-wrapper"><img src="https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg" loading="lazy" alt="" class="i-author w-dyn-bind-empty">
                          <div class="spacer-horizontal-xs"></div>
                          <div class="div-author-name">
                            <p class="text-size-small left-align w-dyn-bind-empty"></p>
                            <div class="spacer-xs"></div>
                            <p class="text-size-tiny w-dyn-bind-empty"></p>
                          </div>
                        </div>
                      </a>
                      <div class="spacer_small"></div>
                      <p class="w-dyn-bind-empty"></p>
                      <div class="spacer_small"></div>
                      <a href="#" class="underlined">Learn more</a>
                    </div>
                  </div>
                </div>
              </div>
              <div class="w-dyn-empty">
                <div>No items found.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>
</Base>
